# Copy to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

# ── MLflow remote tracking ───────────────────────────────────────────────────
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
# MLFLOW_TRACKING_TOKEN=   # alternative: bearer token auth

# ── S3 buckets ───────────────────────────────────────────────────────────────
S3_FILE_BUCKET=
S3_SENTINEL_BUCKET=sentinel
S3_TEMPORAL_BUCKET=temporal-messaging
S3_TEMP_BUCKET=temp

# ── S3 / AWS-compatible endpoint ─────────────────────────────────────────────
AWS_VIRTUAL_HOSTING="FALSE"
AWS_HTTPS="YES"
AWS_REGION=us-east-1
AWS_S3_ENDPOINT=s3.tytonai.com
AWS_SESSION_TOKEN=
AWS_SECRET_ACCESS_KEY=
AWS_ACCESS_KEY_ID=default
